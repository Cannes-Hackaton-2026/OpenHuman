# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://humanproof:humanproof@localhost:5432/humanproof"

# ─── World ID ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MOCK_WORLDID="true"          # "true" in dev, "false" for staging/demo
NEXT_PUBLIC_APP_ID="app_staging_xxx"     # from developer.world.org
RP_SIGNING_KEY=""                  # RP signing key from developer.world.org
RP_ID=""                           # RP ID from developer.world.org

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET="dev-secret-change-me"    # random secret for JWT signing

# ─── Hedera Testnet ───────────────────────────────────────────────────────────
HEDERA_ACCOUNT_ID=""                     # from portal.hedera.com
HEDERA_PRIVATE_KEY=""                    # ECDSA private key

# ─── World AgentKit ───────────────────────────────────────────────────────────
AGENTKIT_APP_ID=""                       # from developer.world.org

# ─── Claude Agent ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""                     # Claude API key — required for agent quality review
AGENT_SERVER_URL="http://localhost:3000" # OpenHuman server URL for the agent
AGENT_WALLET="0x000000000000000000000000000000000000CAFE"  # Agent's wallet address

# ─── Demo / Admin ─────────────────────────────────────────────────────────────
ADMIN_RESET_KEY="dev-reset-key"          # secret key for /api/admin/reset
ANTHROPIC_API_KEY=""
